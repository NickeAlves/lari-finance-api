DATABASE_URL=jdbc:postgresql://<database-host>:<database-port>/<database-name>
DATABASE_USERNAME=<database-user>
DATABASE_PASSWORD=<database-password>
JWT_SECRET=<random-secret-with-at-least-32-bytes>
JWT_EXPIRATION=<expiration-in-milliseconds>
CORS_ALLOWED_ORIGINS=<frontend-origin>
SERVER_PORT=<api-port>
REGISTRATION_ENABLED=<true-or-false>
SPRINGDOC_ENABLED=<true-or-false>

POSTGRES_DB=<database-name>

management.endpoints.web.exposure.include=
management.endpoint.health.show-details=